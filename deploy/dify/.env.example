# Dify release tag. Example: 1.10.1
DIFY_VERSION=1.10.1

# Server install directory for the official Dify repository.
DIFY_INSTALL_DIR=/opt/dify

# Public entrypoint settings.
DIFY_SCHEME=http
DIFY_HOST=your-server-ip-or-domain
DIFY_HTTP_PORT=80
DIFY_HTTPS_PORT=443

# Optional: if you run web and api under the same domain, keep these values aligned.
CONSOLE_WEB_URL=
CONSOLE_API_URL=
SERVICE_API_URL=
APP_WEB_URL=
FILES_URL=

# Optional secrets. Leave empty to auto-generate on first install.
SECRET_KEY=
DB_PASSWORD=
REDIS_PASSWORD=
PLUGIN_DAEMON_KEY=
INNER_API_KEY=
INNER_API_KEY_FOR_PLUGIN=
